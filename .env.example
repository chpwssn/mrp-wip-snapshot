# Required
M2M_GRAPHQL_URL=https://m2m-graphql-us.wasson.tech

# Internal API TLS — set to 0 if m2m-graphql uses a self-signed/internal CA
NODE_TLS_REJECT_UNAUTHORIZED=0

# SQLite
DB_PATH=./data/mrp.db

# Optional — Jira (skip gracefully if not set)
# JIRA_CLOUD_ID=e745caae-d769-4c2d-b16b-cf3c6baaa331
# JIRA_EMAIL=your_email@wasson-ece.com
# JIRA_API_TOKEN=your_jira_api_token

# Optional — Notion (skip gracefully if not set)
# NOTION_API_KEY=your_notion_integration_token
NOTION_TRAVELERS_DB_ID=1e5d8349-4976-4ca7-bf90-db56ebb8f9b4

# The Tool (Order Tracking spreadsheet) — adjust path for your server
TOOL_PATH=/Volumes/Documentation/ProductionTool/Master Document/Order Tracking MASTER NEW.xlsx

# Tuning
CONCURRENCY=5
BATCH_DELAY_MS=200
